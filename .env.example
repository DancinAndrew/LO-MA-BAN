# .env.example
# Featherless API Key (https://featherless.ai)
FEATHERLESS_API_URL=https://api.featherless.ai/v1/chat/completions
FEATHERLESS_API_KEY=

# 預設目標網址（測試用）
DEFAULT_TARGET_URL=https://renouvellement-canalplus-fr.com/captcha.php

# 可選：Featherless 模型設定
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_TEMPERATURE=0.1
FEATHERLESS_MAX_TOKENS=1000

# 輸出設定
OUTPUT_DIR=./output
SAVE_INTERMEDIATE=true

# Security API Keys
VIRUSTOTAL_API_KEY=
PHISHTANK_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
URLHAUS_BASE_URL=https://urlhaus-api.abuse.ch/v1
URLHAUS_AUTH_KEY=