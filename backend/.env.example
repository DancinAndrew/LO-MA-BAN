# Featherless AI (OpenAI-compatible)
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_TEMPERATURE=0.1
FEATHERLESS_MAX_TOKENS=2000
FEATHERLESS_TOP_P=0.9

# LLM per-task overrides
CONTENT_CLASSIFY_TEMPERATURE=0.1
CONTENT_CLASSIFY_MAX_TOKENS=400
PERSUASION_TEMPERATURE=0.1
PERSUASION_MAX_TOKENS=1000

# Exa AI — content fetching for age-suitability checks
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_TIMEOUT=60
EXA_MAX_AGE_HOURS=24
EXA_LIVECRAWL_TIMEOUT_MS=25000
EXA_SEARCH_NUM_RESULTS=5

# Content analysis
CONTENT_MAX_CHARS=8000

# Security API keys
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
URLHAUS_AUTH_KEY=
URLHAUS_BASE_URL=https://urlhaus-api.abuse.ch/v1
PHISHTANK_API_KEY=
PHISHTANK_BASE_URL=https://api.phishtank.com/v2/phishtank
GOOGLE_SAFE_BROWSING_API_KEY=
GOOGLE_SAFE_BROWSING_BASE_URL=https://safebrowsing.googleapis.com/v4

# Server
HOST=0.0.0.0
PORT=8000
API_TIMEOUT=30

# App metadata
APP_TITLE=ScoutNet API
APP_VERSION=2.0.0
USER_AGENT=ScamAnalyzer/2.0

# CORS — JSON array or comma-separated origins
CORS_ORIGINS=["*"]
